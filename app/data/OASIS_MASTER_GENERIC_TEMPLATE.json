{
  "assessmentMetadata": {
    "patientName": "[PATIENT_NAME]",
    "patientId": "[PATIENT_ID]",
    "dateOfBirth": "[DOB_YYYY-MM-DD]",
    "socDate": "[SOC_DATE_YYYY-MM-DD]",
    "rocDate": "[ROC_DATE_YYYY-MM-DD_or_null]",
    "episodeNumber": "[EPISODE_NUMBER]",
    "episodePeriodStart": "[START_DATE_YYYY-MM-DD]",
    "episodePeriodEnd": "[END_DATE_YYYY-MM-DD]",
    "assessmentStatus": "[locked_or_draft_or_submitted]",
    "oasisVersion": "OASIS-E-2024"
  },
  "sections": {
    "patient_tracking": {
      "sectionId": "patient_tracking",
      "sectionLabel": "Patient Tracking / Administrative",
      "fields": [
        {
          "fieldCode": "M0010",
          "fieldName": "CMS Certification Number",
          "dataType": "string",
          "required": true,
          "value": "[CERTIFICATION_NUMBER]",
          "example": "067595"
        },
        {
          "fieldCode": "M0014",
          "fieldName": "Branch State",
          "dataType": "string",
          "required": false,
          "value": "[STATE_CODE_or_null]",
          "example": "CO"
        },
        {
          "fieldCode": "M0018",
          "fieldName": "NPI for attending physician",
          "dataType": "string",
          "required": true,
          "value": "[NPI_10_DIGITS]",
          "example": "1447540208"
        },
        {
          "fieldCode": "M0020",
          "fieldName": "Patient ID Number",
          "dataType": "string",
          "required": true,
          "value": "[PATIENT_ID]",
          "example": "6161"
        },
        {
          "fieldCode": "M0030",
          "fieldName": "Start of Care Date",
          "dataType": "date",
          "required": true,
          "value": "[YYYY-MM-DD]",
          "example": "2025-09-09"
        },
        {
          "fieldCode": "M0040",
          "fieldName": "Patient Name",
          "dataType": "string",
          "required": true,
          "value": "[PATIENT_FULL_NAME]",
          "example": "ALLEN, JENNIFER Y"
        },
        {
          "fieldCode": "M0050",
          "fieldName": "Patient State of Residence",
          "dataType": "state_code",
          "required": true,
          "value": "[STATE_CODE]",
          "example": "CO"
        },
        {
          "fieldCode": "M0060",
          "fieldName": "Patient Zip Code",
          "dataType": "string",
          "required": true,
          "value": "[5_DIGIT_ZIP]",
          "example": "80249"
        },
        {
          "fieldCode": "M0066",
          "fieldName": "Birth Date",
          "dataType": "date",
          "required": true,
          "value": "[YYYY-MM-DD]",
          "example": "1974-06-25"
        },
        {
          "fieldCode": "M0069",
          "fieldName": "Gender",
          "dataType": "enum",
          "required": true,
          "value": "[gender_code]",
          "example": "F",
          "options": [
            {
              "code": "M",
              "label": "Male"
            },
            {
              "code": "F",
              "label": "Female"
            }
          ]
        },
        {
          "fieldCode": "M0080",
          "fieldName": "Discipline of person completing assessment",
          "dataType": "oasis_enum",
          "required": true,
          "value": "[discipline_code]",
          "example": "1",
          "options": [
            {
              "code": "1",
              "label": "RN"
            },
            {
              "code": "2",
              "label": "PT"
            },
            {
              "code": "3",
              "label": "SLP/ST"
            },
            {
              "code": "4",
              "label": "OT"
            }
          ]
        },
        {
          "fieldCode": "M0100",
          "fieldName": "Reason assessment is being completed",
          "dataType": "oasis_enum",
          "required": true,
          "value": "[reason_code]",
          "example": "1",
          "options": [
            {
              "code": "1",
              "label": "Start of Care - further visits planned"
            },
            {
              "code": "3",
              "label": "Resumption of care (after inpatient stay)"
            },
            {
              "code": "4",
              "label": "Recertification (follow-up) reassessment"
            },
            {
              "code": "5",
              "label": "Other follow-up"
            },
            {
              "code": "6",
              "label": "Transferred to inpatient - not discharged"
            },
            {
              "code": "7",
              "label": "Transferred to inpatient - discharged"
            },
            {
              "code": "8",
              "label": "Death at home"
            },
            {
              "code": "9",
              "label": "Discharge from agency"
            }
          ]
        },
        {
          "fieldCode": "M0090",
          "fieldName": "Date Assessment Completed",
          "dataType": "date",
          "required": true,
          "value": "[YYYY-MM-DD]",
          "example": "2025-09-10"
        },
        {
          "fieldCode": "M0150",
          "fieldName": "Current Payment Sources for Home Care",
          "dataType": "oasis_enum",
          "required": true,
          "value": "[payment_source_code]",
          "example": "3",
          "options": [
            {
              "code": "1",
              "label": "Medicare (traditional fee-for-service)"
            },
            {
              "code": "2",
              "label": "Medicare (HMO/managed care)"
            },
            {
              "code": "3",
              "label": "Medicaid (traditional fee-for-service)"
            },
            {
              "code": "4",
              "label": "Medicaid (HMO/managed care)"
            },
            {
              "code": "5",
              "label": "Worker's Compensation"
            },
            {
              "code": "6",
              "label": "VA"
            },
            {
              "code": "7",
              "label": "Private insurance"
            },
            {
              "code": "8",
              "label": "Private pay"
            },
            {
              "code": "9",
              "label": "Other"
            }
          ]
        }
      ]
    },
    "patient_history_diagnosis": {
      "sectionId": "patient_history_diagnosis",
      "sectionLabel": "Patient History & Diagnosis",
      "fields": [
        {
          "fieldCode": "M1000",
          "fieldName": "Inpatient facility discharge in last 14 days",
          "dataType": "oasis_enum",
          "required": true,
          "value": "[discharge_source_code]",
          "example": "NA",
          "skipLogic": "If NA, skip to B0200",
          "options": [
            {
              "code": "NA",
              "label": "Patient was not discharged from inpatient facility"
            },
            {
              "code": "1",
              "label": "Long-term nursing facility (NF)"
            },
            {
              "code": "2",
              "label": "Skilled nursing facility (SNF/TCU)"
            },
            {
              "code": "3",
              "label": "Short-stay acute hospital (IPPS)"
            },
            {
              "code": "4",
              "label": "Long-term care hospital (LTCH)"
            },
            {
              "code": "5",
              "label": "Inpatient rehabilitation hospital or unit (IRF)"
            },
            {
              "code": "6",
              "label": "Psychiatric hospital or unit"
            }
          ]
        },
        {
          "fieldCode": "M1005",
          "fieldName": "Inpatient Discharge Date (most recent)",
          "dataType": "date",
          "required": false,
          "value": "[YYYY-MM-DD_or_null]",
          "example": "2025-09-08",
          "notes": "Required if M1000 is not NA"
        },
        {
          "fieldCode": "M1021",
          "fieldName": "Primary Diagnosis",
          "dataType": "object",
          "required": true,
          "value": {
            "description": "[ICD10_DIAGNOSIS_DESCRIPTION]",
            "icd10Code": "[ICD10_CODE]",
            "symptomControlRating": "[0-4]",
            "onsetDate": "[YYYY-MM-DD]"
          },
          "example": {
            "description": "Type 2 Diabetes Mellitus",
            "icd10Code": "E11.9",
            "symptomControlRating": "2",
            "onsetDate": "2020-03-15"
          }
        },
        {
          "fieldCode": "M1023",
          "fieldName": "Other Diagnoses",
          "dataType": "array",
          "required": false,
          "value": [
            {
              "description": "[ICD10_DIAGNOSIS_DESCRIPTION]",
              "icd10Code": "[ICD10_CODE]",
              "symptomControlRating": "[0-4]"
            }
          ],
          "example": [
            {
              "description": "Essential hypertension",
              "icd10Code": "I10",
              "symptomControlRating": "1"
            }
          ]
        },
        {
          "fieldCode": "M1028",
          "fieldName": "Active Diagnoses \u2013 Comorbidities",
          "dataType": "object",
          "required": false,
          "value": {
            "peripheralVascularDisease": "[true/false]",
            "diabetesMellitus": "[true/false]",
            "noneOfTheAbove": "[true/false]"
          },
          "example": {
            "peripheralVascularDisease": false,
            "diabetesMellitus": true,
            "noneOfTheAbove": false
          }
        },
        {
          "fieldCode": "M1060",
          "fieldName": "Height and Weight",
          "dataType": "object",
          "required": true,
          "value": {
            "heightInches": "[numeric]",
            "weightPounds": "[numeric]",
            "bmi": "[auto-calculated]",
            "patientScaleUsedForWeight": "[true/false]"
          },
          "example": {
            "heightInches": 70,
            "weightPounds": 185,
            "bmi": 26.5,
            "patientScaleUsedForWeight": false
          }
        },
        {
          "fieldCode": "K0520",
          "fieldName": "Nutritional Approaches on Admission",
          "dataType": "array",
          "required": false,
          "value": [
            "[APPROACH_1]"
          ],
          "example": [
            "Therapeutic diet"
          ],
          "validOptions": [
            "Parenteral/IV feeding",
            "Feeding tube",
            "Mechanically altered diet",
            "Therapeutic diet",
            "Fluid restriction"
          ]
        },
        {
          "fieldCode": "O0110",
          "fieldName": "Special Treatments, Procedures, and Programs",
          "dataType": "object",
          "required": false,
          "value": {
            "oxygenTherapy": "[true/false]",
            "ivMedications": "[true/false]",
            "dialysis": "[true/false]",
            "transfusions": "[true/false]"
          },
          "example": {
            "oxygenTherapy": true,
            "ivMedications": false,
            "dialysis": true,
            "transfusions": false
          }
        },
        {
          "fieldCode": "ALLERGIES",
          "fieldName": "Allergies",
          "dataType": "object",
          "required": false,
          "value": {
            "noKnownAllergies": "[true/false]",
            "allergyList": []
          },
          "example": {
            "noKnownAllergies": true,
            "allergyList": []
          }
        }
      ]
    },

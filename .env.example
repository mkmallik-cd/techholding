APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8081

DATABASE_URL=postgresql+psycopg2://postgres:postgres@postgres:5432/patient_generation

CELERY_BROKER_URL=amqp://guest:guest@rabbitmq:5672//
CELERY_RESULT_BACKEND=rpc://
CELERY_QUEUE_NAME=patient_generation.step1

AWS_REGION=us-east-1
DEFAULT_BEDROCK_MODEL_ID=us.anthropic.claude-3-5-sonnet-20241022-v2:0

OUTPUT_BASE_DIR=/app/output

# ── Langfuse observability (optional) ────────────────────────────────────────
# Set LANGFUSE_ENABLED=true and provide keys to enable LLM tracing.
# Create a project at http://localhost:3000 (self-hosted) to get the keys.
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000
